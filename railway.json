{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "command": "pip install -r requirements.txt",
    "builder": "NIXPACKS"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "command": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port $PORT"
  }
}